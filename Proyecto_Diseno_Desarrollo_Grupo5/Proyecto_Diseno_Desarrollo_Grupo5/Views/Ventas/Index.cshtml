@model System.Collections.Generic.List<Proyecto_Diseno_Desarrollo_Grupo5.Models.VentaFilaVM>

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Ventas.css" />
}

<div class="ventas-wrap">

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Ventas</h2>
            <div class="page-subtitle">Historial, pagos y cancelaciones</div>
        </div>

        <a class="btn btn-primary" href="@Url.Action("Create","Ventas")">+ Nueva venta</a>
    </div>

    @if (TempData["OK"] != null)
    {
        <div class="alert alert-success">@TempData["OK"]</div>
    }

    @if (TempData["ERR"] != null)
    {
        <div class="alert alert-danger">@TempData["ERR"]</div>
    }

    <div class="page-section mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-12">
                <label class="form-label" style="font-weight:700;">Buscar</label>
                <input id="busquedaVentas"
                       class="form-control"
                       type="text"
                       placeholder="Buscar cliente, fecha, total, estado..." />
            </div>
        </div>
    </div>

    <div class="page-section">
        <div class="p-tableWrap">
            <table class="p-table" id="tablaVentas">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th style="width:180px;">Fecha</th>
                        <th style="width:120px;">Total</th>
                        <th style="width:120px;">Pagado</th>
                        <th style="width:120px;">Saldo</th>
                        <th style="width:130px;">Estado</th>
                        <th style="width:260px; text-align:right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        var isActiva = v.IdEstado == 1;
                        var tieneSaldo = v.Saldo > 0;

                        <tr>
                            <td>@v.Cliente</td>
                            <td>@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@v.Total</td>
                            <td>@v.Pagado</td>
                            <td>@v.Saldo</td>
                            <td>
                                @if (isActiva)
                                {
                                    <span class="badge-pill badge-ok">ACTIVA</span>
                                }
                                else
                                {
                                    <span class="badge-pill badge-off">CANCELADA</span>
                                }
                            </td>
                            <td style="text-align:right;">
                                <div class="d-flex gap-2 justify-content-end flex-wrap">

                                    @if (isActiva && tieneSaldo)
                                    {
                                        <button type="button"
                                                class="btn-icon btn-pagar"
                                                title="Pagar"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalPago"
                                                onclick="cargarPago('@v.IdVenta','@v.Saldo')">
                                            💳
                                        </button>
                                    }

                                    @if (isActiva)
                                    {
                                        <form method="post" action="@Url.Action("Cancelar","Ventas")" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.IdVenta" />

                                            <button type="submit"
                                                    class="btn-icon btn-cancelar"
                                                    title="Cancelar venta"
                                                    onclick="return confirm('¿Cancelar la venta #@v.IdVenta?')">
                                                ❌
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin acciones</span>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @{
            var current = (int)(ViewBag.Page ?? 1);
            var total = (int)(ViewBag.TotalPages ?? 1);
            int start = Math.Max(1, current - 2);
            int end = Math.Min(total, current + 2);
            var q = (string)(ViewBag.Q ?? "");
        }

        <nav aria-label="Paginación" class="mt-3">
            <ul class="pagination">
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = q, page = current - 1 })">Anterior</a>
                </li>

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { q = q, page = i })">@i</a>
                    </li>
                }

                <li class="page-item @(current >= total ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = q, page = current + 1 })">Siguiente</a>
                </li>
            </ul>
        </nav>

    </div>

</div>

<div class="modal fade" id="modalPago" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Registrar pago</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            @using (Html.BeginForm("Pagar", "Ventas", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="modal-body">
                    <input type="hidden" name="IdVenta" id="pago_IdVenta" />

                    <div class="mb-2">
                        <label class="form-label" style="font-weight:700;">Monto</label>
                        <input class="form-control"
                               type="number"
                               step="0.01"
                               min="0.01"
                               name="Monto"
                               id="pago_Monto"
                               required />
                        <div class="text-muted" style="font-size:12px; margin-top:6px;">
                            Saldo pendiente: <b id="pago_SaldoTxt"></b>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label" style="font-weight:700;">Método</label>
                        <select class="form-select" name="Metodo" id="pago_Metodo" required>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Tarjeta">Tarjeta</option>
                            <option value="Transferencia">Transferencia</option>
                            <option value="Sinpe">SINPE</option>
                        </select>
                    </div>

                    <div class="mb-2 d-none" id="bloqueComprobanteSinpe">
                        <label class="form-label" style="font-weight:700;">Comprobante SINPE</label>
                        <input class="form-control"
                               type="file"
                               name="comprobanteSinpe"
                               id="comprobanteSinpe"
                               accept="image/*" />
                        <div class="text-muted" style="font-size:12px; margin-top:6px;">
                            Adjunte una imagen del comprobante.
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label" style="font-weight:700;">Referencia (opcional)</label>
                        <input class="form-control"
                               name="Referencia"
                               placeholder="Ej: #Comprobante / Banco..." />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" style="border-radius:12px; font-weight:900;">
                        Guardar pago
                    </button>
                </div>
            }

        </div>
    </div>
</div>

            @section scripts{
                <script>
                    function toggleComprobanteSinpe() {
                        const metodo = document.getElementById("pago_Metodo").value;
                        const bloque = document.getElementById("bloqueComprobanteSinpe");
                        const input = document.getElementById("comprobanteSinpe");

                        if (metodo === "Sinpe") {
                            bloque.classList.remove("d-none");
                            input.required = true;
                        } else {
                            bloque.classList.add("d-none");
                            input.required = false;
                            input.value = "";
                        }
                    }

                    function cargarPago(idVenta, saldo) {
                        document.getElementById("pago_IdVenta").value = idVenta;
                        document.getElementById("pago_SaldoTxt").innerText = saldo;
                        document.getElementById("pago_Monto").value = saldo;

                        const metodo = document.getElementById("pago_Metodo");
                        if (metodo) {
                            metodo.value = "Efectivo";
                            toggleComprobanteSinpe();
                        }
                    }

                    document.addEventListener("DOMContentLoaded", function () {
                        const input = document.getElementById("busquedaVentas");
                        const filas = document.querySelectorAll("#tablaVentas tbody tr");

                        input.addEventListener("keyup", function () {
                            const filtro = input.value.toLowerCase().trim();

                            filas.forEach(function (fila) {
                                const textoFila = fila.innerText.toLowerCase();

                                if (textoFila.includes(filtro)) {
                                    fila.style.display = "";
                                } else {
                                    fila.style.display = "none";
                                }
                            });
                        });

                        const metodo = document.getElementById("pago_Metodo");
                        if (metodo) {
                            metodo.addEventListener("change", toggleComprobanteSinpe);
                            toggleComprobanteSinpe();
                        }
                    });
                </script>
            }
