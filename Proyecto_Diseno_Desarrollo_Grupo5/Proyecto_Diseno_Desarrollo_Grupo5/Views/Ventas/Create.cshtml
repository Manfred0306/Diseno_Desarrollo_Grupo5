﻿@model Proyecto_Diseno_Desarrollo_Grupo5.Models.VentaCrearVM

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Ventas.css" />
}

<div class="ventas-wrap">

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Nueva venta</h2>
            <div class="page-subtitle">Agregá productos, calculá total y guardá la transacción</div>
        </div>

        <a class="btn btn-outline-secondary" href="@Url.Action("Index","Ventas")">Volver</a>
    </div>

    @if (TempData["ERR"] != null)
    {<div class="alert alert-danger">@TempData["ERR"]</div>}

    @using (Html.BeginForm("Create", "Ventas", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="page-section mb-3">
            <div class="col-md-6 position-relative">
                <label class="form-label" style="font-weight:800;">Cliente</label>

                <input type="text"
                       id="clienteBusqueda"
                       class="form-control"
                       placeholder="Escriba nombre, teléfono o correo..."
                       autocomplete="off" />

                <input type="hidden" name="IdCliente" id="IdCliente" required />

                <div id="clienteResultados" class="cliente-resultados d-none"></div>

                <small id="clienteSeleccionadoTxt" class="text-muted d-block mt-2">
                    No hay cliente seleccionado.
                </small>
            </div>

            <div class="col-md-6">
                <div class="total-box">
                    <span>Total</span>
                    <b id="totalTxt">0.00</b>
                </div>
            </div>
        </div>

    <div class="page-section mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label" style="font-weight:800;">Producto</label>
                @Html.DropDownList("productoSelect", Model.Productos, "Seleccione un producto", new { @class = "form-select" })
            </div>

            <div class="col-md-2">
                <label class="form-label" style="font-weight:800;">Cantidad</label>
                <input class="form-control" type="number" step="0.01" min="0.01" id="cantInput" />
            </div>

            <div class="col-md-3">
                <label class="form-label" style="font-weight:800;">Precio Unitario</label>
                <input class="form-control" type="number" step="0.01" min="0" id="precioInput" />
            </div>

            <div class="col-md-2">
                <button type="button" class="btn btn-dark w-100"
                        style="height:44px; border-radius:12px; font-weight:900;"
                        onclick="agregarItem()">
                    + Agregar
                </button>
            </div>
        </div>

        <div class="text-muted mt-2" style="font-size:12px;">
            El inventario de materiales se descuenta automáticamente según la receta del producto (PRODUCTO_MATERIAL).
        </div>
    </div>

    <div class="page-section">
        <div class="table-wrap">
            <table class="table mb-0" id="tablaDetalle">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th style="width:120px;">Cantidad</th>
                        <th style="width:150px;">Precio</th>
                        <th style="width:150px;">Subtotal</th>
                        <th style="width:120px; text-align:right;">Acción</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="submit" class="btn btn-primary"
                    style="border-radius:12px; font-weight:900;">
                Guardar venta
            </button>
        </div>
    </div>

    <div id="hiddenContainer"></div>
}
    </div>

    @section scripts{
        <script>
        function money(n) {
            return (Math.round(n * 100) / 100).toFixed(2);
        }

        function recalcularTotal() {
            let total = 0;
            document.querySelectorAll("#tablaDetalle tbody tr").forEach(tr => {
                total += parseFloat(tr.getAttribute("data-subtotal")) || 0;
            });
            document.getElementById("totalTxt").innerText = money(total);
        }

        function agregarItem() {
            const sel = document.getElementsByName("productoSelect")[0];
            const idProd = sel.value;
            const prodText = sel.options[sel.selectedIndex]?.text || "";

            const cant = parseFloat(document.getElementById("cantInput").value);
            const precio = parseFloat(document.getElementById("precioInput").value);

            if (!idProd) { alert("Seleccione un producto"); return; }
            if (!cant || cant <= 0) { alert("Cantidad inválida"); return; }
            if (precio == null || isNaN(precio) || precio < 0) { alert("Precio inválido"); return; }

            const subtotal = cant * precio;

            const tbody = document.querySelector("#tablaDetalle tbody");
            const tr = document.createElement("tr");
            tr.setAttribute("data-subtotal", subtotal);

            tr.innerHTML = `
                <td>${prodText}</td>
                <td>${money(cant)}</td>
                <td>${money(precio)}</td>
                <td>${money(subtotal)}</td>
                <td style="text-align:right;">
                    <button type="button" class="btn-soft btn-soft-danger" onclick="quitarItem(this)">Quitar</button>
                </td>
            `;
            tbody.appendChild(tr);

            const hidden = document.getElementById("hiddenContainer");
            hidden.insertAdjacentHTML("beforeend", `
                <input type="hidden" name="IdProducto" value="${idProd}" />
                <input type="hidden" name="Cantidad" value="${cant}" />
                <input type="hidden" name="PrecioUnitario" value="${precio}" />
            `);

            document.getElementById("cantInput").value = "";
            document.getElementById("precioInput").value = "";
            sel.selectedIndex = 0;

            recalcularTotal();
        }

        function quitarItem(btn) {
            const tr = btn.closest("tr");
            const index = Array.from(tr.parentNode.children).indexOf(tr);

            tr.remove();

            const hidden = document.querySelectorAll("#hiddenContainer input");
            const base = index * 3;
            if (hidden[base]) hidden[base].remove();
            if (hidden[base + 1]) hidden[base + 1].remove();
            if (hidden[base + 2]) hidden[base + 2].remove();

            recalcularTotal();
        }

        // ===== BUSCADOR PROFESIONAL DE CLIENTES =====
        const clienteBusqueda = document.getElementById("clienteBusqueda");
        const clienteResultados = document.getElementById("clienteResultados");
        const idClienteInput = document.getElementById("IdCliente");
        const clienteSeleccionadoTxt = document.getElementById("clienteSeleccionadoTxt");

        let timeoutCliente = null;

        clienteBusqueda.addEventListener("keyup", function () {
            const valor = this.value.trim();

            idClienteInput.value = "";
            clienteSeleccionadoTxt.innerText = "No hay cliente seleccionado.";

            clearTimeout(timeoutCliente);

            if (valor.length < 2) {
                clienteResultados.innerHTML = "";
                clienteResultados.classList.add("d-none");
                return;
            }

            timeoutCliente = setTimeout(function () {
                fetch('@Url.Action("BuscarClientes", "Ventas")?term=' + encodeURIComponent(valor))
                    .then(r => r.json())
                    .then(data => {
                        clienteResultados.innerHTML = "";

                        if (!data || data.length === 0) {
                            clienteResultados.innerHTML = `
                                <div class="cliente-item">
                                    <b>Sin resultados</b>
                                    <span>No se encontraron clientes.</span>
                                </div>`;
                            clienteResultados.classList.remove("d-none");
                            return;
                        }

                        data.forEach(c => {
                            const item = document.createElement("div");
                            item.className = "cliente-item";
                            item.innerHTML = `
                                <b>${c.nombre}</b>
                                <span>${c.telefono || ""} ${c.correo ? "· " + c.correo : ""}</span>
                            `;

                            item.addEventListener("click", function () {
                                clienteBusqueda.value = c.nombre;
                                idClienteInput.value = c.id;
                                clienteSeleccionadoTxt.innerText = "Cliente seleccionado: " + c.nombre;
                                clienteResultados.classList.add("d-none");
                            });

                            clienteResultados.appendChild(item);
                        });

                        clienteResultados.classList.remove("d-none");
                    });
            }, 250);
        });

        document.addEventListener("click", function (e) {
            if (!clienteBusqueda.contains(e.target) && !clienteResultados.contains(e.target)) {
                clienteResultados.classList.add("d-none");
            }
        });
        </script>
    }