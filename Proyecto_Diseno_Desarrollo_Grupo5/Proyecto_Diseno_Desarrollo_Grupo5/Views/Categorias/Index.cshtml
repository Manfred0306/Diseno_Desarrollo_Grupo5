@model Proyecto_Diseno_Desarrollo_Grupo5.Models.CategoriaCrudVM
@{
    ViewBag.Title = "Categorías";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/StaticFiles/css/Index.css" />
    <link rel="stylesheet" href="~/StaticFiles/css/Footer.css" />
    <link rel="stylesheet" href="~/StaticFiles/css/Productos.css" />
}

<section class="page-hero">
    <div class="lp-wrap">
        <div class="hero" style="grid-template-columns: 1fr;">
            <div class="hero__left" style="padding: 34px 34px;">
                <span class="hero__kicker">Módulo</span>
                <h1>Categorías</h1>
                <p>
                    Registrar, editar y desactivar categorías rápidamente.
                    Seleccioná una fila para editar o desactivar.
                </p>

                <div class="hero__cta">
                    <a class="lp-btn" href="@Url.Action("Index","Home")">
                        Volver al inicio
                    </a>
                    <a class="btn2" href="#panel-form">
                        Ir al formulario
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="lp-section">
    <div class="lp-wrap">

        @if (TempData["OK"] != null)
        {
            <div class="alert alert-success" style="margin-bottom:12px;">@TempData["OK"]</div>
        }
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-warning" style="margin-bottom:12px;">@TempData["Mensaje"]</div>
        }

        <div class="panel p-panel" id="panel-form">
            <div class="p-head">
                <div class="p-title">
                    <h2>Registro y mantenimiento</h2>
                    <span class="muted">Click en una fila para cargar datos y editar.</span>
                </div>
                <span class="p-chip">CRUD</span>
            </div>

            <div class="p-search">
                <input id="txtBuscar" placeholder="Buscar por nombre o descripción..." />
            </div>

            @using (Html.BeginForm("Create", "Categorias", FormMethod.Post, new { id = "frmCategoria" }))
            {
                @Html.AntiForgeryToken()

                <input type="hidden" id="ID_CATEGORIA" name="ID_CATEGORIA" value="0" />

                <div class="p-form" style="grid-template-columns: 1.2fr 2fr 1fr;">
                    <div class="p-field">
                        <label>Nombre</label>
                        <input id="NOMBRE" name="NOMBRE" required />
                    </div>

                    <div class="p-field">
                        <label>Descripción</label>
                        <input id="DESCRIPCION" name="DESCRIPCION" />
                    </div>

                    <div class="p-field">
                        <label>Estado</label>
                        <select id="ID_ESTADO" name="ID_ESTADO" required>
                            @foreach (var e in Model.Estados)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="p-actions">
                    <button type="submit" id="btnGuardar" class="lp-btn">Guardar</button>
                    <button type="button" id="btnCancelar" class="btn2">Cancelar</button>
                    <button type="button" id="btnDesactivar" class="lp-btn p-danger" disabled>Desactivar</button>
                </div>
            }
        </div>

        <div class="panel p-panel" style="margin-top:12px;">
            <div class="p-head">
                <div class="p-title">
                    <h2>Lista general</h2>
                    <span class="muted">Se actualiza cuando guardás, editás o desactivás.</span>
                </div>
                <span class="p-chip">@Model.Categorias.Count registros</span>
            </div>

            <div class="p-tableWrap">
                <table id="tblCategorias" class="p-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Categorias)
                        {
                            <tr class="rowCat"
                                data-id="@c.ID_CATEGORIA"
                                data-nombre="@c.NOMBRE"
                                data-descripcion="@c.DESCRIPCION"
                                data-estado="@c.ID_ESTADO">

                                <td class="colNombre">@c.NOMBRE</td>
                                <td class="colDescripcion">@c.DESCRIPCION</td>
                                <td>@c.ESTADO</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @using (Html.BeginForm("Deactivate", "Categorias", FormMethod.Post, new { id = "frmDeactivate" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" id="deactivateId" name="id" value="0" />
            }
        </div>

    </div>
</section>

<script>
    var txtBuscar = document.getElementById("txtBuscar");
    var filas = function() { return document.querySelectorAll("#tblCategorias tbody tr"); };

    txtBuscar.addEventListener("keyup", function () {
        var q = txtBuscar.value.toLowerCase().trim();

        filas().forEach(function(tr) {
            var id = (tr.dataset.id || "").toLowerCase();
            var nombre = (tr.querySelector(".colNombre") ? tr.querySelector(".colNombre").innerText : "").toLowerCase();
            var desc = (tr.querySelector(".colDescripcion") ? tr.querySelector(".colDescripcion").innerText : "").toLowerCase();

            tr.style.display = (id.indexOf(q) >= 0 || nombre.indexOf(q) >= 0 || desc.indexOf(q) >= 0) ? "" : "none";
        });
    });

    var frm = document.getElementById("frmCategoria");
    var btnDesactivar = document.getElementById("btnDesactivar");

    function limpiar() {
        document.getElementById("ID_CATEGORIA").value = 0;
        document.getElementById("NOMBRE").value = "";
        document.getElementById("DESCRIPCION").value = "";
        document.getElementById("ID_ESTADO").value = "1";

        frm.action = "@Url.Action("Create", "Categorias")";
        btnDesactivar.disabled = true;

        filas().forEach(function(x) { x.classList.remove("p-selected"); });
    }

    document.getElementById("btnCancelar").addEventListener("click", limpiar);

    filas().forEach(function(tr) {
        tr.addEventListener("click", function () {
            filas().forEach(function(x) { x.classList.remove("p-selected"); });
            tr.classList.add("p-selected");

            document.getElementById("ID_CATEGORIA").value = tr.dataset.id;
            document.getElementById("NOMBRE").value = tr.dataset.nombre;
            document.getElementById("DESCRIPCION").value = tr.dataset.descripcion;
            document.getElementById("ID_ESTADO").value = tr.dataset.estado;

            frm.action = "@Url.Action("Edit", "Categorias")";
            btnDesactivar.disabled = false;
        });
    });

    btnDesactivar.addEventListener("click", function () {
        var id = document.getElementById("ID_CATEGORIA").value;
        if (id == 0) return;

        if (confirm("żConfirma desactivar esta categoría? Esta acción la pondrá como Inactiva.")) {
            document.getElementById("deactivateId").value = id;
            document.getElementById("frmDeactivate").submit();
        }
    });
</script>
