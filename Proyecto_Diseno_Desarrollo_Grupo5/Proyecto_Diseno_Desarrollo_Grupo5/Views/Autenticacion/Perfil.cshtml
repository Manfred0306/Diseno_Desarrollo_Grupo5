@model Proyecto_Diseno_Desarrollo_Grupo5.Models.PerfilVM

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Perfil.css" />
}

@{
    var iniciales = "?";

    if (!string.IsNullOrWhiteSpace(Model.Nombre))
    {
        var parts = Model.Nombre.Trim().Split(' ');

        if (parts.Length == 1)
        {
            iniciales = parts[0].Substring(0, 1).ToUpper();
        }
        else
        {
            iniciales = (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
        }
    }
}

<div class="page-wrap">

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Mi perfil</h2>
            <div class="page-subtitle">Información de tu cuenta en AlphaStock</div>
        </div>

        <a class="btn btn-outline-secondary" href="@Url.Action("Index","Home")">Volver</a>
    </div>

    <div class="row g-3">

        <!-- CARD PRINCIPAL -->
        <div class="col-lg-7">
            <div class="cardx">

                <div class="profile-top">
                    <div class="d-flex align-items-center gap-3">
                        <div class="avatar">@iniciales</div>

                        <div>
                            <div style="font-weight:900; font-size:18px;">@Model.Nombre</div>
                            <div style="color:#6c757d;">@Model.Correo</div>
                        </div>
                    </div>

                    @if (Model.Estado == "ACTIVO")
                    {
                        <span class="pill pill-ok">ACTIVO</span>
                    }
                    else
                    {
                        <span class="pill pill-off">INACTIVO</span>
                    }
                </div>

                <div class="mini-line"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="label">ID Usuario</div>
                        <div class="value">@Model.IdUsuario</div>
                    </div>

                    <div class="col-md-8">
                        <div class="label">Rol</div>
                        <div class="value">@Model.Rol</div>
                    </div>

                    <div class="col-md-12">
                        <div class="label">Correo</div>
                        <div class="value">@Model.Correo</div>
                    </div>
                </div>

            </div>
        </div>

        <!-- ACCIONES -->
        <div class="col-lg-5">
            <div class="cardx">
                <div style="font-weight:900; font-size:16px;" class="mb-2">Acciones</div>
                <div class="page-subtitle mb-3">Opciones rápidas para tu cuenta.</div>

                <button class="btn btn-dark w-100 mb-2" disabled>
                    Cambiar contraseña (próximamente)
                </button>

                <a class="btn btn-outline-danger w-100" href="@Url.Action("Logout","Autenticacion")">
                    Cerrar sesión
                </a>
            </div>

            <div class="cardx mt-3">
                <div style="font-weight:900; font-size:16px;" class="mb-2">Seguridad</div>
                <div class="page-subtitle">
                    Recomendación: usá una contraseña segura y no la compartás.
                </div>
            </div>
        </div>

    </div>

</div>