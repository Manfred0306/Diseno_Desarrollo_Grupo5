@using System.Web
@model Proyecto_Diseno_Desarrollo_Grupo5.Models.ProveedorCrudVM
@{
    ViewBag.Title = "Proveedores";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Cliente.css" />
}

<div class="container" style="max-width:1100px; padding-top:30px;">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Control de Proveedores</h2>
            <div class="page-subtitle">Gestión de proveedores (crear, editar, inactivar)</div>
        </div>

        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrear">
            + Nuevo Proveedor
        </button>
    </div>

    @if (TempData["OK"] != null)
    {
        <div class="alert alert-success cardx" style="padding:12px 14px;">@TempData["OK"]</div>
    }
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-warning cardx" style="padding:12px 14px;">@TempData["Mensaje"]</div>
    }

    <div class="page-section mb-3">
        @using (Html.BeginForm("Index", "Proveedores", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label" style="font-weight:600;">Buscar</label>
                    <input type="text" name="q" value="@Model.Q" class="form-control" placeholder="Nombre, contacto o teléfono" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark w-100" style="height:44px; border-radius:10px; font-weight:600;">🔍 Buscar</button>
                </div>
            </div>
        }
    </div>

    <div class="page-section mt-3">
        <div class="cardx table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Empresa</th>
                        <th>Contacto</th>
                        <th>Teléfono</th>
                        <th>Materiales</th>
                        <th>Estado</th>
                        <th style="width:220px; text-align:right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Proveedores)
                    {
                        <tr>
                            <td>@p.NOMBRE</td>
                            <td>@p.CONTACTO</td>
                            <td>@p.TELEFONO</td>
                            <td>@p.CANTIDAD_MATERIALES</td>
                            <td>
                                <span class="badge-pill @(p.ID_ESTADO == 1 ? "badge-ok" : "badge-off")">
                                    @(p.ID_ESTADO == 1 ? "ACTIVO" : "INACTIVO")
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-primary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditar"
                                        onclick="cargarProveedorEditar('@p.ID_PROVEEDOR', '@Html.Raw(HttpUtility.JavaScriptStringEncode(p.NOMBRE ?? ""))', '@Html.Raw(HttpUtility.JavaScriptStringEncode(p.CONTACTO ?? ""))', '@Html.Raw(HttpUtility.JavaScriptStringEncode(p.TELEFONO ?? ""))', '@p.ID_ESTADO')">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                @using (Html.BeginForm("Deactivate", "Proveedores", FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.ID_PROVEEDOR" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="q" value="@Model.Q" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Inactivar este proveedor?');">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Paginación" class="mt-3">
            <ul class="pagination">
                @{
                    var current = Model.Page;
                    var total = Model.TotalPages;
                    int start = Math.Max(1, current - 2);
                    int end = Math.Min(total, current + 2);
                }

                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current - 1 })">Anterior</a>
                </li>

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = i })">@i</a>
                    </li>
                }

                <li class="page-item @(current >= total ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current + 1 })">Siguiente</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Nuevo proveedor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Create", "Proveedores", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre de empresa</label>
                        <input class="form-control" name="NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre de contacto</label>
                        <input class="form-control" name="CONTACTO" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" name="TELEFONO" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Editar proveedor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Edit", "Proveedores", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID_PROVEEDOR" id="edit_ID_PROVEEDOR" />
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre de empresa</label>
                        <input class="form-control" name="NOMBRE" id="edit_NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Nombre de contacto</label>
                        <input class="form-control" name="CONTACTO" id="edit_CONTACTO" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" name="TELEFONO" id="edit_TELEFONO" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Estado</label>
                        <select class="form-select" name="ID_ESTADO" id="edit_ID_ESTADO" required>
                            @foreach (var e in Model.Estados)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar cambios</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function cargarProveedorEditar(id, nombre, contacto, telefono, idEstado) {
        document.getElementById("edit_ID_PROVEEDOR").value = id;
        document.getElementById("edit_NOMBRE").value = nombre;
        document.getElementById("edit_CONTACTO").value = contacto;
        document.getElementById("edit_TELEFONO").value = telefono;
        document.getElementById("edit_ID_ESTADO").value = idEstado;
    }
</script>
