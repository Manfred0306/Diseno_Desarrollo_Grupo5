@using System.Web
@model Proyecto_Diseno_Desarrollo_Grupo5.Models.ClienteCrudVM

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Cliente.css" />
}

<div class="container" style="max-width:1100px; padding-top:30px;">

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Control de Clientes</h2>
            <div class="page-subtitle">
                Gestión de clientes (crear, editar, activar/inactivar)
            </div>
        </div>

        <button type="button" class="btn btn-primary"
                data-bs-toggle="modal" data-bs-target="#modalCrear">
            + Nuevo Cliente
        </button>
    </div>

    @if (TempData["OK"] != null)
    {
        <div class="alert alert-success cardx" style="padding:12px 14px;">@TempData["OK"]</div>
    }
    @if (TempData["ERR"] != null)
    {
        <div class="alert alert-danger cardx" style="padding:12px 14px;">@TempData["ERR"]</div>
    }


    <div class="page-section">
        <div class="page-section mb-3">
            @using (Html.BeginForm("Index", "Clientes", FormMethod.Get))
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label" style="font-weight:600;">Buscar</label>
                        <input type="text" name="q" value="@Model.Q"
                               class="form-control" placeholder="Nombre, Telefono o Correo" />
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-dark w-100"
                                style="height:44px; border-radius:10px; font-weight:600;">
                            🔍 Buscar
                        </button>
                    </div>
                </div>
                <input type="hidden" name="page" value="@Model.Page" />
            }
        </div>

    </div>

<div class="page-section mt-3">
    <div class="cardx table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>
                        <a class="sort-link"
                           href="@Url.Action("Index", new { q = Model.Q, sortOrder = ViewBag.NameSortParm, page = Model.Page })">
                            Cliente
                            <span class="sort-ico">
                                @(Request["sortOrder"] == "name_desc" ? "⬇" : "⬆")
                            </span>
                        </a>
                    </th>
                    <th style="width:150px;">Teléfono</th>
                    <th>Correo</th>
                    <th>Dirección</th>
                    <th style="width:130px;">Estado</th>
                    <th style="width:240px; text-align:right;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Clientes)
                {
                    <tr>
                        <td>
                            <div class="chip">
                                <div>
                                    <div style="font-weight:900;">@c.NOMBRE</div>
                                </div>
                            </div>
                        </td>
                        <td>@c.TELEFONO</td>
                        <td>@c.CORREO</td>
                        <td>@c.DIRECCION</td>
                        <td>
                            <span class="badge-pill @(c.ID_ESTADO == 1 ? "badge-ok" : "badge-off")">
                                @(c.ID_ESTADO == 1 ? "ACTIVO" : "INACTIVO")
                            </span>
                        </td>

                        <td class="text-end" style="width:100px;">
                            <button class="btn btn-outline-primary btn-sm me-1"
                                    title="Editar"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalEditar"
                                    onclick="cargarClienteEditar('@c.ID_CLIENTE',
              '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(c.NOMBRE ?? ""))',
              '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(c.TELEFONO ?? ""))',
              '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(c.CORREO ?? ""))',
              '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(c.DIRECCION ?? ""))',
              '@c.ID_ESTADO')">
                                <i class="bi bi-pencil-square"></i>
                            </button>

                            @using (Html.BeginForm("ToggleEstado", "Clientes", FormMethod.Post, new { style = "display:inline;" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.ID_CLIENTE" />
                                <input type="hidden" name="q" value="@Model.Q" />
                                <input type="hidden" name="sortOrder" value="@Request["sortOrder"]" />
                                <input type="hidden" name="page" value="@Model.Page" />

                                var esActivo = (c.ID_ESTADO == 1);

                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm"
                                        title="@(esActivo ? "Inactivar" : "Activar")">
                                    <i class="bi @(esActivo ? "bi-person-x" : "bi-person-check")"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <nav aria-label="Paginación" class="mt-3">
        <ul class="pagination">
            @{
                var current = Model.Page;
                var total = Model.TotalPages;
                int start = Math.Max(1, current - 2);
                int end = Math.Min(total, current + 2);
            }

            <li class="page-item @(current == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, sortOrder = Request["sortOrder"], page = current - 1 })">Anterior</a>
            </li>

            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, sortOrder = Request["sortOrder"], page = i })">@i</a>
                </li>
            }

            <li class="page-item @(current >= total ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, sortOrder = Request["sortOrder"], page = current + 1 })">Siguiente</a>
            </li>
        </ul>
    </nav>

    <div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" style="font-weight:900;">Nuevo cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                @using (Html.BeginForm("Create", "Clientes", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="modal-body">
                        <div class="mb-2">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" name="NOMBRE" required />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Teléfono</label>
                            <input class="form-control" name="TELEFONO" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Correo</label>
                            <input class="form-control" name="CORREO" type="email" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Dirección</label>
                            <input class="form-control" name="DIRECCION" />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-primary-pill" style="box-shadow:none;">Guardar</button>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalEditar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" style="font-weight:900;">Editar cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                @using (Html.BeginForm("Edit", "Clientes", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="modal-body">
                        <input type="hidden" name="ID_CLIENTE" id="edit_ID_CLIENTE" />
                        <input type="hidden" name="Q" value="@Model.Q" />
                        <input type="hidden" name="Page" value="@Model.Page" />

                        <div class="mb-2">
                            <label class="form-label">Nombre</label>
                            <input class="form-control" name="NOMBRE" id="edit_NOMBRE" required />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Teléfono</label>
                            <input class="form-control" name="TELEFONO" id="edit_TELEFONO" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Correo</label>
                            <input class="form-control" name="CORREO" id="edit_CORREO" type="email" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Dirección</label>
                            <input class="form-control" name="DIRECCION" id="edit_DIRECCION" />
                        </div>

                        <input type="hidden" name="ID_ESTADO" id="edit_ID_ESTADO" />
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-primary-pill" style="box-shadow:none;">Guardar cambios</button>
                    </div>
                }
            </div>
        </div>
    </div>


</div>

</div>

<script>
    function cargarClienteEditar(id, nombre, telefono, correo, direccion, idEstado) {
        document.getElementById("edit_ID_CLIENTE").value = id;
        document.getElementById("edit_NOMBRE").value = nombre;
        document.getElementById("edit_TELEFONO").value = telefono;
        document.getElementById("edit_CORREO").value = correo;
        document.getElementById("edit_DIRECCION").value = direccion;
        document.getElementById("edit_ID_ESTADO").value = idEstado;
    }
</script>
