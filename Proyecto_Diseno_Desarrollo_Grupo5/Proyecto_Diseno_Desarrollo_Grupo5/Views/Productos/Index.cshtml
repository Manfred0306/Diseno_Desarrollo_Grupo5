@using System.Web
@model Proyecto_Diseno_Desarrollo_Grupo5.Models.ProductoCrudVM
@{
    ViewBag.Title = "Productos";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/StaticFiles/css/Cliente.css" />
}

<div class="container" style="max-width:1100px; padding-top:30px;">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Control de Productos</h2>
            <div class="page-subtitle">Gestión de productos (crear, editar, eliminar)</div>
        </div>

        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrear">
            + Nuevo Producto
        </button>
    </div>

    @if (TempData["OK"] != null)
    {
        <div class="alert alert-success cardx" style="padding:12px 14px;">@TempData["OK"]</div>
    }
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-warning cardx" style="padding:12px 14px;">@TempData["Mensaje"]</div>
    }

    <div class="page-section mb-3">
        @using (Html.BeginForm("Index", "Productos", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label" style="font-weight:600;">Buscar</label>
                    <input type="text" name="q" value="@Model.Q" class="form-control" placeholder="Nombre o categoría" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark w-100" style="height:44px; border-radius:10px; font-weight:600;">🔎 Buscar</button>
                </div>
            </div>
        }
    </div>

    <div class="page-section mt-3">
        <div class="cardx table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Categoría</th>
                        <th>Estado</th>
                        <th style="width:220px; text-align:right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Productos)
                    {
                        <tr>
                            <td>@p.NOMBRE</td>
                            <td>₡@p.PRECIO_VENTA.ToString("N2")</td>
                            <td>@p.CATEGORIA</td>
                            <td>@p.ESTADO</td>
                            <td class="text-end">
                                <button class="btn btn-outline-primary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditar"
                                        onclick="cargarProductoEditar('@p.ID_PRODUCTO', '@Html.Raw(HttpUtility.JavaScriptStringEncode(p.NOMBRE ?? ""))', '@p.PRECIO_VENTA', '@p.ID_CATEGORIA', '@p.ID_ESTADO')">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                @using (Html.BeginForm("Delete", "Productos", FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.ID_PRODUCTO" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="q" value="@Model.Q" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar este producto?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Paginación" class="mt-3">
            <ul class="pagination">
                @{
                    var current = Model.Page;
                    var total = Model.TotalPages;
                    int start = Math.Max(1, current - 2);
                    int end = Math.Min(total, current + 2);
                }

                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current - 1 })">Anterior</a>
                </li>

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = i })">@i</a>
                    </li>
                }

                <li class="page-item @(current >= total ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current + 1 })">Siguiente</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Nuevo producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Create", "Productos", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" name="NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Precio de venta</label>
                        <input class="form-control" name="PRECIO_VENTA" type="number" step="0.01" min="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Categoría</label>
                        <select class="form-select" name="ID_CATEGORIA" required>
                            <option value="">-- Seleccione --</option>
                            @foreach (var c in Model.Categorias)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Estado</label>
                        <select class="form-select" name="ID_ESTADO" required>
                            @foreach (var e in Model.Estados)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Editar producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Edit", "Productos", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID_PRODUCTO" id="edit_ID_PRODUCTO" />
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" name="NOMBRE" id="edit_NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Precio de venta</label>
                        <input class="form-control" name="PRECIO_VENTA" id="edit_PRECIO_VENTA" type="number" step="0.01" min="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Categoría</label>
                        <select class="form-select" name="ID_CATEGORIA" id="edit_ID_CATEGORIA" required>
                            @foreach (var c in Model.Categorias)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Estado</label>
                        <select class="form-select" name="ID_ESTADO" id="edit_ID_ESTADO" required>
                            @foreach (var e in Model.Estados)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar cambios</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function cargarProductoEditar(id, nombre, precio, idCategoria, idEstado) {
        document.getElementById("edit_ID_PRODUCTO").value = id;
        document.getElementById("edit_NOMBRE").value = nombre;
        document.getElementById("edit_PRECIO_VENTA").value = precio;
        document.getElementById("edit_ID_CATEGORIA").value = idCategoria;
        document.getElementById("edit_ID_ESTADO").value = idEstado;
    }
</script>
