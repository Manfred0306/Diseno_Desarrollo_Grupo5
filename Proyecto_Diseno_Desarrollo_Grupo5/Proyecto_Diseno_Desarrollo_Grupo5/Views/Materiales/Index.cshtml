@using System.Web
@model Proyecto_Diseno_Desarrollo_Grupo5.Models.MaterialCrudVM
@{
    ViewBag.Title = "Materiales";
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
}

@section styles{
    <link rel="stylesheet" href="~/StaticFiles/css/Cliente.css" />
}

<div class="container" style="max-width:1200px; padding-top:30px;">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h2 class="page-title">Control de Materiales</h2>
            <div class="page-subtitle">Gestión de materiales (crear, editar, eliminar y ajustar stock)</div>
        </div>

        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrear">
            + Nuevo Material
        </button>
    </div>

    @if (TempData["OK"] != null)
    {
        <div class="alert alert-success cardx" style="padding:12px 14px;">@TempData["OK"]</div>
    }
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-warning cardx" style="padding:12px 14px;">@TempData["Mensaje"]</div>
    }

    <div class="page-section mb-3">
        @using (Html.BeginForm("Index", "Materiales", FormMethod.Get))
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label" style="font-weight:600;">Buscar</label>
                    <input type="text" name="q" value="@Model.Q" class="form-control" placeholder="Nombre, tipo o proveedor" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark w-100" style="height:44px; border-radius:10px; font-weight:600;">🔎 Buscar</button>
                </div>
            </div>
        }
    </div>

    <div class="page-section mt-3">
        <div class="cardx table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Stock</th>
                        <th>Costo Unit.</th>
                        <th>Proveedor</th>
                        <th>Estado</th>
                        <th>Alerta</th>
                        <th style="width:260px; text-align:right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Materiales)
                    {
                        <tr>
                            <td>@m.NOMBRE</td>
                            <td>@m.TIPO</td>
                            <td>@m.STOCK</td>
                            <td>₡@m.COSTO_UNITARIO.ToString("N2")</td>
                            <td>@m.PROVEEDOR</td>
                            <td>@m.ESTADO</td>
                            <td>
                                @if (m.STOCK_BAJO)
                                {
                                    <span style="color:#dc3545;font-weight:800;">Stock bajo</span>
                                }
                                else
                                {
                                    <span style="color:#198754;font-weight:800;">OK</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-outline-primary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalEditar"
                                        onclick="cargarMaterialEditar('@m.ID_MATERIAL', '@Html.Raw(HttpUtility.JavaScriptStringEncode(m.NOMBRE ?? ""))', '@Html.Raw(HttpUtility.JavaScriptStringEncode(m.TIPO ?? ""))', '@m.STOCK', '@m.COSTO_UNITARIO', '@m.ID_PROVEEDOR', '@m.ID_ESTADO')">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                <button class="btn btn-outline-secondary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalAjuste"
                                        onclick="cargarAjuste('@m.ID_MATERIAL', '@Html.Raw(HttpUtility.JavaScriptStringEncode(m.NOMBRE ?? ""))', '@m.STOCK')">
                                    <i class="bi bi-sliders"></i>
                                </button>

                                @using (Html.BeginForm("Delete", "Materiales", FormMethod.Post, new { style = "display:inline;" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@m.ID_MATERIAL" />
                                    <input type="hidden" name="page" value="@Model.Page" />
                                    <input type="hidden" name="q" value="@Model.Q" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar este material?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Paginación" class="mt-3">
            <ul class="pagination">
                @{
                    var current = Model.Page;
                    var total = Model.TotalPages;
                    int start = Math.Max(1, current - 2);
                    int end = Math.Min(total, current + 2);
                }

                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current - 1 })">Anterior</a>
                </li>

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = i })">@i</a>
                    </li>
                }

                <li class="page-item @(current >= total ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { q = Model.Q, page = current + 1 })">Siguiente</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<div class="modal fade" id="modalCrear" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Nuevo material</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Create", "Materiales", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" name="NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Tipo de material</label>
                        <select class="form-select" name="TIPO" required>
                            <option value="">-- Seleccione tipo --</option>
                            <option value="Granito">Granito</option>
                            <option value="Mármol">Mármol</option>
                            <option value="Cuarzo">Cuarzo</option>
                            <option value="Piedra Natural">Piedra Natural</option>
                            <option value="Cerámica">Cerámica</option>
                            <option value="Porcelanato">Porcelanato</option>
                            <option value="Herramienta">Herramienta</option>
                            <option value="Insumo">Insumo</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Unidad de medida</label>
                        <select class="form-select" name="UNIDAD_MEDIDA">
                            <option value="m²">m² (metro cuadrado)</option>
                            <option value="m³">m³ (metro cúbico)</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Stock actual</label>
                        <input class="form-control" name="STOCK" type="number" step="0.01" min="0" value="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Costo unitario (₡)</label>
                        <input class="form-control" name="COSTO_UNITARIO" type="number" step="0.01" min="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Proveedor</label>
                        <select class="form-select" name="ID_PROVEEDOR" required>
                            <option value="">-- Seleccione --</option>
                            @foreach (var p in Model.Proveedores)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Editar material</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Edit", "Materiales", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID_MATERIAL" id="edit_ID_MATERIAL" />
                <input type="hidden" name="Page" value="@Model.Page" />
                <input type="hidden" name="Q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" name="NOMBRE" id="edit_NOMBRE" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Tipo de material</label>
                        <select class="form-select" name="TIPO" id="edit_TIPO" required>
                            <option value="Granito">Granito</option>
                            <option value="Mármol">Mármol</option>
                            <option value="Cuarzo">Cuarzo</option>
                            <option value="Piedra Natural">Piedra Natural</option>
                            <option value="Cerámica">Cerámica</option>
                            <option value="Porcelanato">Porcelanato</option>
                            <option value="Herramienta">Herramienta</option>
                            <option value="Insumo">Insumo</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Stock actual</label>
                        <input class="form-control" name="STOCK" id="edit_STOCK" type="number" step="0.01" min="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Costo unitario (₡)</label>
                        <input class="form-control" name="COSTO_UNITARIO" id="edit_COSTO_UNITARIO" type="number" step="0.01" min="0" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Proveedor</label>
                        <select class="form-select" name="ID_PROVEEDOR" id="edit_ID_PROVEEDOR" required>
                            @foreach (var p in Model.Proveedores)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Estado</label>
                        <select class="form-select" name="ID_ESTADO" id="edit_ID_ESTADO" required>
                            @foreach (var e in Model.Estados)
                            {
                                <option value="@e.Value">@e.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Guardar cambios</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="modalAjuste" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-weight:900;">Ajuste manual de stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("AjustarStock", "Materiales", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID_MATERIAL" id="ajuste_ID_MATERIAL" />
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="q" value="@Model.Q" />
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label">Material seleccionado</label>
                        <input class="form-control" id="ajuste_nombre" readonly />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Cantidad de ajuste (+/-)</label>
                        <input class="form-control" name="AJUSTE_CANTIDAD" type="number" step="0.01" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Observación</label>
                        <input class="form-control" name="AJUSTE_OBSERVACION" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-primary-pill">Aplicar ajuste</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function cargarMaterialEditar(id, nombre, tipo, stock, costo, idProveedor, idEstado) {
        document.getElementById("edit_ID_MATERIAL").value = id;
        document.getElementById("edit_NOMBRE").value = nombre;
        document.getElementById("edit_TIPO").value = tipo;
        document.getElementById("edit_STOCK").value = stock;
        document.getElementById("edit_COSTO_UNITARIO").value = costo;
        document.getElementById("edit_ID_PROVEEDOR").value = idProveedor;
        document.getElementById("edit_ID_ESTADO").value = idEstado;
    }

    function cargarAjuste(id, nombre, stock) {
        document.getElementById("ajuste_ID_MATERIAL").value = id;
        document.getElementById("ajuste_nombre").value = nombre + " (Stock actual: " + stock + ")";
    }
</script>
